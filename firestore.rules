rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================
    // HELPER FUNCTIONS (SAFE & DEFENSIVE)
    // =========================================================

    // 1. Check if user is authenticated and has a valid identity
    function isSignedIn() {
      return request.auth != null && 
             request.auth.token.firebase.identities.size() > 0;
    }

    // 2. Check if user document exists
    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // 3. Safe fetch of user data
    function getUserDataSafe() {
      return userExists() 
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data 
        : null;
    }

    // 4. Get user role
    function getUserRole() {
      let data = getUserDataSafe();
      return data != null ? data.role : null;
    }

    // 5. Multi-Tenancy check
    function isSameCompany(resourceData) {
      let myCompanyId = getUserDataSafe().companyId;
      return isSignedIn() && (
        getUserRole() == 'super_admin' || 
        (myCompanyId != null && resourceData.companyId == myCompanyId)
      );
    }

    // =========================================================
    // COLLECTIONS
    // =========================================================

    // --- COMPANIES ---
    match /companies/{companyId} {
      allow read: if isSignedIn() && (
        getUserRole() == 'super_admin' || 
        (getUserDataSafe().companyId == companyId)
      );
      allow write: if isSignedIn() && getUserRole() == 'super_admin';
    }

    // --- USERS ---
    match /users/{userId} {
      allow read: if isSignedIn() && (
        request.auth.uid == userId || 
        isSameCompany(resource.data)
      );
      allow create: if isSignedIn() && (
        request.auth.uid == userId ||
        (getUserRole() in ['manager', 'admin', 'super_admin'])
      );
      allow update: if isSignedIn() && (
        request.auth.uid == userId ||
        (isSameCompany(resource.data) && getUserRole() in ['manager', 'admin', 'super_admin'])
      );
      allow delete: if isSignedIn() && getUserRole() == 'super_admin';
    }

    // --- JOBS ---
    match /jobs/{jobId} {
      allow read: if isSignedIn() && isSameCompany(resource.data);
      allow create: if false; // Only via backend Cloud Function
      allow update: if isSignedIn() && isSameCompany(resource.data) && (
        getUserRole() in ['manager', 'admin', 'dispatch', 'driver']
      );

      match /logs/{logId} {
        allow read: if isSignedIn() && isSameCompany(get(/databases/$(database)/documents/jobs/$(jobId)).data);
        allow create: if isSignedIn();
      }
    }

    // --- VEHICLES ---
    match /vehicles/{vehicleId} {
      allow read: if isSignedIn() && isSameCompany(resource.data);
      allow write: if isSignedIn() && getUserRole() in ['manager', 'admin', 'dispatch', 'super_admin'];
    }

    // --- SUBSCRIPTION & PAYMENT (READ-ONLY FOR USERS) ---
    
    match /customers/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if false; // Backend only
    }

    match /subscriptions/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if false; // Backend only
    }

    match /invoices/{invoiceId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow write: if false; // Backend only
    }

    // --- METADATA (PUBLIC CONTENT) ---
    // Blog posts and marketing content (landing page, pricing)
    match /metadata/{docId} {
      // Anyone can read public content
      allow read: if true;
      // Only authenticated users can write (DevPanel uses custom session)
      // In production, you may want to add custom claims check
      allow write: if request.auth != null;
    }

    // Prevent unauthorized access to other collections
    match /{path=**} {
      allow read, write: if isSignedIn() && getUserRole() == 'super_admin';
    }
  }
}
